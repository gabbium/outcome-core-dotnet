<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup Label="Package info">
    <PackageId>OutcomeCore</PackageId>
    <PackageDescription>Lightweight result pattern and error modeling primitives for .NET applications.</PackageDescription>
    <PackageTags>result;outcome;error;clean-architecture;ddd</PackageTags>
    <Authors>Gabriel (@gabbium)</Authors>
    <PackageProjectUrl>https://github.com/gabbium/outcome-core-dotnet</PackageProjectUrl>
    <RepositoryUrl>https://github.com/gabbium/outcome-core-dotnet</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup Label="Package files">
    <None Include="..\..\README.md" Visible="false" Pack="true" PackagePath="\" />
    <None Include="..\..\LICENSE" Visible="false" Pack="true" PackagePath="\" />
  </ItemGroup>
  
</Project>
